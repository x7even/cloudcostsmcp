# OpenCloudCosts Test Harness — Local Configuration
#
# Copy this file to .env (same directory) and fill in your values.
# .env is gitignored — never commit it.
#
# The harness works with any OpenAI-compatible LLM server:
#   LM Studio    https://lmstudio.ai
#   Ollama       https://ollama.ai  (with the OpenAI-compatible endpoint)
#   OpenAI       https://api.openai.com
#   Together AI  https://api.together.ai
#   Local vLLM   http://localhost:8000

# Base URL of your LLM server (no trailing slash, no /v1 suffix)
OCC_LLM_BASE_URL=http://localhost:1234

# Model identifier exactly as reported by the server
# LM Studio:  check the "Identifier" field in the model card
# OpenAI:     e.g. gpt-4o, gpt-4-turbo
# Ollama:     e.g. llama3.1:70b, qwen2.5:72b
OCC_LLM_MODEL=your-model-name-here

# API key — required for OpenAI, Together AI, and other hosted providers.
# Leave commented out for local servers (LM Studio, Ollama, vLLM).
# OCC_LLM_API_KEY=sk-...
