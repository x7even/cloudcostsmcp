# OpenCloudCosts Test Harness — Local Configuration
#
# Copy this file to .env (same directory) and fill in your values.
# .env is gitignored — never commit it.
#
# The harness works with any OpenAI-compatible LLM server:
#   vLLM         http://127.0.0.1:8080  (no /v1 suffix — harness appends it)
#   Ollama       http://localhost:11434
#   OpenAI       https://api.openai.com
#   Together AI  https://api.together.ai

# Base URL of your LLM server (no trailing slash, no /v1 suffix — harness appends /v1/chat/completions)
OCC_LLM_BASE_URL=http://127.0.0.1:8080

# Model identifier exactly as reported by the server (/v1/models)
# vLLM:    e.g. qwen3.6-35b-fast
# OpenAI:  e.g. gpt-4o, gpt-4-turbo
# Ollama:  e.g. llama3.1:70b, qwen2.5:72b
OCC_LLM_MODEL=qwen3.6-35b-fast

# API key — required for OpenAI, Together AI, and other hosted providers.
# Leave commented out for local servers (vLLM, Ollama).
# OCC_LLM_API_KEY=sk-...

# HTTP MCP endpoint — when set, workers connect to a running MCP server over HTTP
# instead of spawning a local stdio process. Use this to point at the containerised
# server on your local network. All parallel workers share one warm server + cache.
# Leave commented out to use stdio (spawns uv run opencloudcosts locally).
OCC_MCP_URL=http://192.168.50.17:8080/mcp
