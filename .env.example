# OpenCloudCosts MCP Server — Configuration
# Copy this file to .env and fill in the values you need.
# Public AWS and Azure pricing works without any credentials.

# --- General ---
# OCC_CACHE_DIR=~/.cache/opencloudcosts
# OCC_CACHE_TTL_HOURS=24
# OCC_DEFAULT_CURRENCY=USD
# OCC_DEFAULT_REGIONS=us-east-1,us-west-2

# --- AWS (optional — public pricing works without auth) ---
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
#
# Enable Cost Explorer for effective/bespoke pricing (note: costs $0.01/API call)
# OCC_AWS_ENABLE_COST_EXPLORER=false

# --- GCP (requires free API key — see README GCP Setup section) ---
# OCC_GCP_API_KEY=AIza...
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Azure (no credentials needed — public pricing is fully open) ---
# (no configuration required)
