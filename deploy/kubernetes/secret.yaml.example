# Populate the values below and apply with:
#   kubectl apply -f secret.yaml
#
# NEVER commit this file with real values — add secret.yaml to .gitignore
# or manage secrets with an external tool (Sealed Secrets, External Secrets
# Operator, AWS Secrets Manager, GCP Secret Manager, etc.).
#
# On EKS, prefer IRSA (IAM Roles for Service Accounts) so no AWS keys are
# needed at all. On GKE, prefer Workload Identity for the same reason.
#
# Encoding a value for stringData is not required — Kubernetes handles it.
# If you use the `data` block instead, values must be base64-encoded:
#   echo -n "my-api-key" | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: opencloudcosts-credentials
  namespace: opencloudcosts
type: Opaque
stringData:
  # ── AWS ──────────────────────────────────────────────────────────────────
  # Leave blank if using IRSA or public pricing only.
  AWS_DEFAULT_REGION: "us-east-1"
  AWS_ACCESS_KEY_ID: ""
  AWS_SECRET_ACCESS_KEY: ""
  OCC_AWS_ENABLE_COST_EXPLORER: "false"

  # ── GCP ──────────────────────────────────────────────────────────────────
  # Leave blank if using Workload Identity or ADC.
  # Use ONE of the following options:
  OCC_GCP_API_KEY: ""
  # OCC_GCP_SERVICE_ACCOUNT_JSON_B64: ""   # base64 -w0 service-account.json

  # ── General ──────────────────────────────────────────────────────────────
  OCC_CACHE_TTL_HOURS: "24"
